  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "LLM cost USD by model",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {"align": "auto", "displayMode": "auto"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [{"id": "displayName", "value": "Cost (USD)"}]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {"show": true, "reducer": ["sum"], "fields": ""}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (model) (increase(rag_llm_cost_usd_total[$__range]))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "indexByName": {"model": 0, "Value": 1},
            "renameByName": {}
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Embedding cost USD by model",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {"align": "auto", "displayMode": "auto"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [{"id": "displayName", "value": "Cost (USD)"}]
          }
        ]
      },
      "options": {
        "showHeader": true,

      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (model) (increase(rag_embedding_cost_usd_total[$__range]))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "indexByName": {"model": 0, "Value": 1},
            "renameByName": {}
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Cost per Library (last 7d)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 25}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (library_id) (increase(rag_llm_cost_usd_total[7d])) + sum by (library_id) (increase(rag_embedding_cost_usd_total[7d]))",
          "legendFormat": "{{library_id}}",
          "instant": true

# RAG-KG Copilot — Environment Variables
# Copy to .env and fill in real values

# === Data Layer ===
POSTGRES_URL=postgresql+asyncpg://rkb:rkb@localhost:5432/rkb
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
OPENSEARCH_URL=http://localhost:9200
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kb

# === LLM (OpenAI-compatible API) ===
# Works with: OpenAI, DeepSeek, vLLM, LiteLLM, any /v1/chat/completions endpoint
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-placeholder
LLM_MODEL=gpt-4o-mini

# === Embedding (OpenAI-compatible API) ===
# Works with: OpenAI, Qwen (DashScope), vLLM, Ollama, any /v1/embeddings endpoint
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-placeholder
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TIMEOUT_S=30

# === Reranker (OpenAI-compatible /v1/rerank) ===
# Works with: SiliconFlow, Jina, Cohere, any /v1/rerank endpoint
RERANK_API_BASE=https://api.siliconflow.cn/v1
RERANK_API_KEY=sk-placeholder
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_ENABLED=true

# === Hybrid retrieval ===
HYBRID_ENABLED=true
HYBRID_K_VECTOR=20
HYBRID_K_BM25=20
HYBRID_RRF_K=60
HYBRID_K_FINAL=8

# === KG extraction ===
KG_ENABLED=true
KG_CHUNKS_PER_CALL=5
KG_MAX_CONCURRENT=2

# === Community detection / global search (M3) ===
COMMUNITY_ENABLED=true
COMMUNITY_MIN_SIZE=3
COMMUNITY_MAX_LEVELS=2
COMMUNITY_RANDOM_SEED=42
COMMUNITY_SUMMARY_MAX_ENTITIES=30
COMMUNITY_SUMMARY_MAX_TRIPLES=80
COMMUNITY_SUMMARY_MAX_CONCURRENT=2
GLOBAL_SEARCH_K=5

# === Agentic retrieval (M4) ===
# planner: routed (M3 default) | direct | hybrid | global | react
PLANNER=routed
REACT_MAX_STEPS=8
REACT_MAX_LLM_CALLS=20
REACT_MAX_INPUT_TOKENS=32000
REACT_MAX_OUTPUT_TOKENS=4000
REACT_TIMEOUT_S=180
REACT_VECTOR_K=5
REACT_BM25_K=5
REACT_KG_DEPTH=1

# === Data Directory ===
DATA_DIR=data

# === Observability ===
LANGFUSE_PUBLIC_KEY=placeholder
LANGFUSE_SECRET_KEY=placeholder
LANGFUSE_HOST=http://localhost:3000

# === App ===
LOG_LEVEL=INFO
DEBUG=false
